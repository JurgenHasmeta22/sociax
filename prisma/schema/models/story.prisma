enum StoryPrivacy {
    Public
    FriendsOnly
    CloseFriends
}

model Story {
    id        Int          @id @default(autoincrement())
    mediaUrl  String
    caption   String?
    privacy   StoryPrivacy @default(FriendsOnly)
    expiresAt DateTime
    createdAt DateTime     @default(now())

    // FK Keys
    userId Int

    // Relations
    user      User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    views     StoryView[]
    reactions StoryReaction[]
    comments  StoryComment[]

    @@index([userId])
    @@index([expiresAt])
    @@index([createdAt])
}

model StoryView {
    id        Int      @id @default(autoincrement())
    viewedAt  DateTime @default(now())

    // FK Keys
    storyId Int
    userId  Int

    // Relations
    story Story @relation(fields: [storyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([storyId, userId])
    @@index([storyId])
}

model StoryReaction {
    id        Int          @id @default(autoincrement())
    reaction  ReactionType @default(Like)
    createdAt DateTime     @default(now())

    // FK Keys
    storyId Int
    userId  Int

    // Relations
    story Story @relation(fields: [storyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([storyId, userId])
    @@index([storyId])
}

model StoryComment {
    id        Int      @id @default(autoincrement())
    content   String
    createdAt DateTime @default(now())

    // FK Keys
    storyId Int
    userId  Int

    // Relations
    story Story @relation(fields: [storyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([storyId])
    @@index([userId])
}
