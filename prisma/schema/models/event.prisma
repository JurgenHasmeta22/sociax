enum EventPrivacy {
    Public
    FriendsOnly
    Private
}

enum AttendeeStatus {
    Going
    Interested
    NotGoing
}

model Event {
    id          Int          @id @default(autoincrement())
    title       String
    slug        String       @unique
    description String?
    coverUrl    String?
    location    String?
    isOnline    Boolean      @default(false)
    onlineLink  String?
    privacy     EventPrivacy @default(Public)
    startDate   DateTime
    endDate     DateTime?
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt

    // FK Keys
    creatorId Int

    // Relations
    creator   User            @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    attendees EventAttendee[]
    posts     EventPost[]
    hashtags  EventHashtag[]

    @@index([creatorId])
    @@index([startDate])
    @@index([privacy])
    @@index([createdAt])
}

model EventAttendee {
    id        Int            @id @default(autoincrement())
    status    AttendeeStatus @default(Interested)
    createdAt DateTime       @default(now())
    updatedAt DateTime       @updatedAt

    // FK Keys
    eventId Int
    userId  Int

    // Relations
    event Event @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([eventId, userId])
    @@index([eventId])
    @@index([status])
}

model EventPost {
    id        Int      @id @default(autoincrement())
    content   String?
    mediaUrl  String?
    isDeleted Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // FK Keys
    eventId Int
    userId  Int

    // Relations
    event    Event              @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user     User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    likes    EventPostLike[]
    comments EventPostComment[]

    @@index([eventId])
    @@index([userId])
    @@index([createdAt])
}

model EventPostLike {
    id           Int          @id @default(autoincrement())
    reactionType ReactionType @default(Like)
    createdAt    DateTime     @default(now())

    // FK Keys
    userId      Int
    eventPostId Int

    // Relations
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    eventPost EventPost @relation(fields: [eventPostId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([userId, eventPostId])
    @@index([eventPostId])
}

model EventPostComment {
    id        Int      @id @default(autoincrement())
    content   String
    mediaUrl  String?
    isDeleted Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // FK Keys
    userId      Int
    eventPostId Int

    // Relations
    user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    eventPost EventPost              @relation(fields: [eventPostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    likes     EventPostCommentLike[]

    @@index([eventPostId])
    @@index([userId])
}

model EventPostCommentLike {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())

    // FK Keys
    userId             Int
    eventPostCommentId Int

    // Relations
    user             User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    eventPostComment EventPostComment @relation(fields: [eventPostCommentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([userId, eventPostCommentId])
    @@index([eventPostCommentId])
}

model EventHashtag {
    id Int @id @default(autoincrement())

    // FK Keys
    eventId   Int
    hashtagId Int

    // Relations
    event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([eventId, hashtagId])
}
