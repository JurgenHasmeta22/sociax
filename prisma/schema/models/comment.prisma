model PostComment {
    id        Int       @id @default(autoincrement())
    content   String
    mediaUrl  String?
    isEdited  Boolean   @default(false)
    isDeleted Boolean   @default(false)
    createdAt DateTime  @default(now())
    updatedAt DateTime? @updatedAt
    deletedAt DateTime?

    // FK Keys
    postId Int
    userId Int

    // Relations
    post    Post           @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user    User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    likes   CommentLike[]
    replies CommentReply[]

    @@index([postId])
    @@index([userId])
    @@index([createdAt])
}

model CommentLike {
    id           Int          @id @default(autoincrement())
    reactionType ReactionType @default(Like)
    createdAt    DateTime     @default(now())

    // FK Keys
    userId    Int
    commentId Int

    // Relations
    user    User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([userId, commentId])
    @@index([commentId])
}

model CommentReply {
    id        Int       @id @default(autoincrement())
    content   String
    isEdited  Boolean   @default(false)
    isDeleted Boolean   @default(false)
    createdAt DateTime  @default(now())
    updatedAt DateTime? @updatedAt
    deletedAt DateTime?

    // FK Keys
    commentId Int
    userId    Int

    // Relations
    comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user    User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    likes   ReplyLike[]

    @@index([commentId])
    @@index([userId])
    @@index([createdAt])
}

model ReplyLike {
    id           Int          @id @default(autoincrement())
    reactionType ReactionType @default(Like)
    createdAt    DateTime     @default(now())

    // FK Keys
    userId  Int
    replyId Int

    // Relations
    user  User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    reply CommentReply @relation(fields: [replyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([userId, replyId])
    @@index([replyId])
}
